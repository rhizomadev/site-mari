---
---
<section class="hero animate-in animate-up" id="inicio">
  <div class="hero__bg"></div>
  <div class="hero__content">
    <div class="hero__symbol-wrap">
      <img src="/Mariana Strelow - Logo1.png" alt="" class="hero__symbol" aria-hidden="true" />
    </div>
    <div class="hero__text-wrap">
      <h1 class="hero__name"><span>Mariana</span> <span>Strelow</span></h1>
      <p class="hero__headline">Psicoterapia — Atendimento Online</p>
      <p class="hero__subheadline">Escuta qualificada para seu processo de autoconhecimento</p>
    </div>
  </div>
  <div class="hero__transition" aria-hidden="true">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="var(--color-bg)"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    padding: calc(4rem + 56px) var(--container-padding) 6rem;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero-dark);
    z-index: 0;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 56rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .hero__symbol-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__symbol {
    width: min(45vw, 320px);
    height: auto;
    filter: drop-shadow(0 0 40px rgba(231, 76, 60, 0.2));
  }

  .hero__text-wrap {
    text-align: left;
  }

  .hero__name {
    margin: 0 0 var(--space-md);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-hero-text);
    line-height: 1.1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35em;
    align-items: baseline;
  }

  .hero__headline {
    margin: 0 0 var(--space-xs);
    font-family: var(--font-body);
    font-size: clamp(1.15rem, 2.2vw, 1.4rem);
    font-weight: 500;
    color: var(--color-accent);
  }

  .hero__subheadline {
    margin: 0;
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    color: var(--color-hero-muted);
  }

  .hero__transition {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100px;
    z-index: 2;
  }

  .hero__transition svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: calc(3.5rem + 56px) var(--container-padding) 5rem;
    }

    .hero__content {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
      text-align: center;
    }

    .hero__text-wrap {
      text-align: center;
    }

    .hero__symbol-wrap {
      display: none;
    }

    .hero__name {
      justify-content: center;
      font-size: clamp(2.25rem, 7vw, 3rem);
    }
  }
</style>
